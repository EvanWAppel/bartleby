    "eslint": "^9.17.0",
    "eslint-plugin-svelte": "^2.46.0",
    "globals": "^17.6.0",
    "jose": "^6.2.3",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "svelte": "^5.16.0",
