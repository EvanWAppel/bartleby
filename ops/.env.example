# Copy to ops/.env (gitignored) and fill in real values before
# `docker compose up -d --build`.

# --- Domain + TLS ---
# Public hostname Caddy will provision a Let's Encrypt cert for.
BARTLEBY_DOMAIN=bartleby.example.com
# Email used for ACME registration.
ACME_EMAIL=admin@example.com
# Same domain as a full URL; used by the server for redirects + email
# links (consumed by Workstream A + M).
PUBLIC_BASE_URL=https://bartleby.example.com

# --- App secrets (used by Workstream A + M as they land) ---
# Comma-separated list of friends' Google account emails.
BARTLEBY_ALLOWED_EMAILS=
# Google OAuth client credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Random 32+ byte secret; `openssl rand -hex 32` is a good source.
SESSION_SECRET=
# Resend API key for @mention email.
RESEND_API_KEY=

# --- Litestream / backups ---
# S3-compatible bucket (Backblaze B2 or Cloudflare R2 recommended).
LITESTREAM_BUCKET=bartleby-backups
# Full endpoint URL including scheme.
# Backblaze B2: https://s3.<region>.backblazeb2.com
# Cloudflare R2: https://<account-id>.r2.cloudflarestorage.com
LITESTREAM_ENDPOINT=
LITESTREAM_REGION=us-east-1
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=

# --- Misc ---
LOG_LEVEL=info
