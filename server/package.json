{
  "name": "@bartleby/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start:test": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate:up": "tsx src/db/migrate.ts up",
    "migrate:down": "tsx src/db/migrate.ts down",
    "migrate:down:all": "tsx src/db/migrate.ts down:all",
    "migrate:status": "tsx src/db/migrate.ts status",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hocuspocus/extension-sqlite": "^4.1.0",
    "@hocuspocus/provider": "^4.1.0",
    "@hocuspocus/server": "^4.1.0",
    "@hono/node-server": "^2.0.4",
    "better-sqlite3": "^12.10.0",
    "hono": "^4.12.23",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.7",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "umzug": "^3.8.3",
    "ws": "^8.21.0",
    "y-prosemirror": "^1.3.7",
    "yaml": "^2.9.0",
    "yjs": "^13.6.30",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.0"
  }
}
