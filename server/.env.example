# Bartleby server — environment variables. Copy this to `.env` and fill in.
# `.env` is gitignored; never commit real credentials.

# --- Workstream A (auth) ---------------------------------------------------

# Comma-separated list of emails permitted to sign in. Any successful Google
# OAuth response with an email NOT on this list is rejected at session
# creation (PRD §9.1). Case-insensitive; whitespace is trimmed.
#   Example: BARTLEBY_ALLOWED_EMAILS=alice@example.com,bob@example.com
BARTLEBY_ALLOWED_EMAILS=

# Google OAuth client (Web application type). Create one at
# https://console.cloud.google.com/apis/credentials. Authorized redirect URI
# must match PUBLIC_BASE_URL + /auth/google/callback exactly.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 32+ chars of entropy used to sign session JWTs (and, later, device-code
# access/refresh tokens). Generate with: openssl rand -base64 48
SESSION_SECRET=

# External base URL of the server (no trailing slash). Used to construct the
# Google OAuth redirect URI and post-login redirect.
#   Local dev: http://localhost:3000
#   Prod: https://bartleby.example.com
PUBLIC_BASE_URL=http://localhost:3000

# --- Ports -----------------------------------------------------------------

# REST/HTTP server port (auth + REST endpoints).
HTTP_PORT=3000

# Hocuspocus WebSocket port (live collab).
PORT=1234

# --- Storage ---------------------------------------------------------------

# SQLite path for Yjs document persistence. `:memory:` for ephemeral.
BARTLEBY_DB_PATH=./bartleby.db

# NODE_ENV controls whether session cookies get the Secure attribute.
# Set to "production" when serving over HTTPS.
NODE_ENV=development
